# ==========================================
# C++ & PyBind11 Compiled Artifacts
# ==========================================
# Ignore compiled shared libraries (Linux/Mac/Windows)
*.so
*.dylib
*.pyd
*.o
*.obj

# Specifically ignoring the PyBind11 output from your build
*cpython-*.so

# ==========================================
# Python Caches & Virtual Environments
# ==========================================
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.env

# ==========================================
# Model Weights & Data
# ==========================================
# NumPy arrays and large vocabulary files are too big for GitHub 
# and should be generated by running the code, not tracked in git.
weights/*.npy
weights/vocab.json

# If you downloaded an arXiv dataset (e.g., CSV, JSON), ignore it
*.csv
*.tsv
data/

# ==========================================
# IDE & System Files
# ==========================================
# VS Code settings
.vscode/

# Code Runner temporary files (visible in your screenshot)
tempCodeRunnerFile.py

# OS generated files
.DS_Store
Thumbs.db

# Processed data
processing/documents_integers.txt
processing/vocab_mapping.json
processing/arxiv-metadata-oai-snapshot.json

# ==========================================
# EXCEPTIONS (What NOT to ignore)
# ==========================================
# We explicitly want to track the results folder for your portfolio
!results/
!results/*.png
!results/*.txt